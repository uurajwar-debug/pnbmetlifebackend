# Backend Environment Variables (copy to .env and fill values)

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server Port
PORT=5000

# JWT Secret (optional)
JWT_SECRET=your-secret-key

# Frontend Environment Variables

# API URL (localhost for dev, your-render-url for production)
VITE_API_URL=http://localhost:5000
